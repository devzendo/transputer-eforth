<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.0.0 http://maven.apache.org/xsd/assembly-2.0.0.xsd">
    <id>transputer</id>
    <formats>
        <format>tar.gz</format>
    </formats>
    <baseDirectory>/</baseDirectory>
    <includeBaseDirectory>true</includeBaseDirectory>

    <fileSets>
        <fileSet>
            <directory>${project.basedir}/eForth</directory>
            <includes>
                <include>EFORTH.BIN</include>
            </includes>
            <outputDirectory>bin</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/eForth</directory>
            <includes>
                <include>EFORTH.ASM</include>
                <include>EFORTH.LST</include>
                <include>EFORTH.SYM</include>
            </includes>
            <outputDirectory>lib/eForth</outputDirectory>
        </fileSet>
    </fileSets>
    <files>
        <file>
            <source>${project.basedir}/README.md</source>
            <outputDirectory>./</outputDirectory>
            <destName>README-transputer-eforth.md</destName>
        </file>
    </files>
</assembly>